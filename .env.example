# LLM Provider Keys (Required for Chat and Delta classification)
OPENAI_API_KEY=your_openai_api_key_here
# If using other providers via LiteLLM, add them here:
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Observability (Arize Phoenix)
# Phoenix typically runs locally on port 6006. If you have a hosted instance or different port, set it here.
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
